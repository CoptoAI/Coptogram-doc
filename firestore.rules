rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Safety Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email_verified == true && (
               exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
               (request.auth.token.email.toLower() == "mokakokaloka90@gmail.com")
             );
    }

    function isValidId(id) {
      return id is string && id.size() <= 256;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidSection(data) {
      return data.id is string &&
             data.title is string &&
             data.category is string &&
             data.content is string &&
             data.order is int &&
             data.content.size() <= 100000;
    }

    function isValidItem(data) {
      return data.id is string &&
             data.title is string &&
             data.description is string &&
             data.order is int &&
             data.description.size() <= 50000;
    }

    function isValidFeedback(data) {
      return data.type in ['positive', 'negative'] &&
             data.sectionId is string &&
             data.itemId is string &&
             data.language is string &&
             data.timestamp == request.time &&
             data.page is string &&
             (!('comment' in data) || (data.comment is string && data.comment.size() <= 2000));
    }

    // --- Collection Routes ---

    // Sections
    match /sections/{sectionId} {
      allow read: if true; // Publicly readable
      allow create, update: if isAdmin() && isValidSection(incoming()) && isValidId(sectionId);
      allow delete: if isAdmin();
      
      // Items subcollection
      match /items/{itemId} {
        allow read: if true; // Publicly readable
        allow create, update: if isAdmin() && isValidItem(incoming()) && isValidId(itemId);
        allow delete: if isAdmin();
      }
    }

    // Admins
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if isAdmin(); // Only admins can manage other admins
    }

    // Feedback
    match /feedback/{feedbackId} {
      allow create: if isValidFeedback(incoming()) && isValidId(feedbackId);
      allow read, list: if isAdmin();
      allow update, delete: if false; // Feedback is immutable once sent
    }

    // Config
    match /config/{configId} {
      allow read: if true; // Publicly readable for landing page settings
      allow write: if isAdmin();
    }
  }
}
